<Window x:Class="CSaVe_Electrochemical_Data.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CSaVe_Electrochemical_Data"
        mc:Ignorable="d"
        Title="CSaVe Electrochemical Data" Height="680" Width="980"
        Background="{DynamicResource AppBackground}">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#F8FAFC"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#94A3B8"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BrowseButton" TargetType="Button">
            <Setter Property="Background" Value="#0891B2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0E7490"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GenerateButton" TargetType="Button">
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#15803D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="ReadOnlyTextBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="#1E293B"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <TabControl Margin="8">
        <TabItem Header="DTA -> CSV">
            <Grid Margin="14,10,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button x:Name="LoadDataButton"
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,6,12,0"
                        Height="46"
                        Style="{StaticResource PrimaryButton}"
                        Content="1. Select Folder with DTA files"
                        Click="LoadDataButton_Click"/>
                <Button x:Name="SelectOutputLocationButton"
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,6,12,0"
                        Height="46"
                        Style="{StaticResource PrimaryButton}"
                        Content="2. Select Folder For Conversions"
                        IsEnabled="False"
                        Click="SelectOutputLocationButton_Click"/>
                <Button x:Name="ConvertFiles"
                        Grid.Row="2"
                        Grid.Column="0"
                        Margin="0,6,12,0"
                        Height="46"
                        Style="{StaticResource PrimaryButton}"
                        Content="3. Convert DTA to CSV"
                        IsEnabled="False"
                        Click="ConvertFiles_Click"/>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,6,0,0">
                    <TextBlock Text="Parent DTA folder:"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="#475569"
                               Margin="0,0,0,3"/>
                    <TextBox x:Name="ParentFolder"
                             Style="{StaticResource ModernTextBox}"
                             HorizontalAlignment="Stretch"
                             Text="Parent DTA folder"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,6,0,0">
                    <TextBlock Text="Output CSV folder:"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="#475569"
                               Margin="0,0,0,3"/>
                    <TextBox x:Name="OutputFolder"
                             Style="{StaticResource ModernTextBox}"
                             HorizontalAlignment="Stretch"
                             Text="Parent CSV folder"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,6,0,0">
                    <TextBlock Text="Status:"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="#475569"
                               Margin="0,0,0,3"/>
                    <TextBox x:Name="StatusBox"
                             Style="{StaticResource ReadOnlyTextBox}"
                             HorizontalAlignment="Stretch"
                             Text="Status"/>
                </StackPanel>

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="Data files found:"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="#1E293B"
                           Margin="0,14,0,4"/>
                <ScrollViewer Grid.Row="4"
                              Grid.Column="0"
                              Grid.ColumnSpan="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="DataFilesTextBox"
                             Style="{StaticResource ReadOnlyTextBox}"
                             Text="Datafiles"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </Grid>
        </TabItem>

        <TabItem Header="Convert CSVs -&gt; XML">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,10,14,10">
                    <GroupBox Header="Input / Output Files">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Button x:Name="BrowseAnodicButton"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Width="220"
                                    Height="32"
                                    Margin="0,4,0,4"
                                    Style="{StaticResource BrowseButton}"
                                    Content="Browse Polarization(or Anodic) CSV"
                                    Click="BrowseAnodicButton_Click"/>
                            <TextBox x:Name="AnodicCsvPath"
                                     Grid.Row="0"
                                     Grid.Column="2"
                                     Margin="0,4,0,4"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="Path to the polarization CSV file (or anodic CSV when using two-file mode)"/>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="3"
                                       Margin="0,2,0,6"
                                       Foreground="#64748B"
                                       FontStyle="Italic"
                                       FontSize="11"
                                       Text="If this file contains both branches, leave the Cathodic CSV field empty."/>

                            <Button x:Name="BrowseCathodicButton"
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Width="220"
                                    Margin="0,4,0,4"
                                    Style="{StaticResource BrowseButton}"
                                    Content="Browse Cathodic CSV (optional)"
                                    Click="BrowseCathodicButton_Click"/>
                            <Grid Grid.Row="2" Grid.Column="2" Margin="0,4,0,4">
                                <TextBox x:Name="CathodicCsvPath"
                                         VerticalAlignment="Center"
                                         Style="{StaticResource ModernTextBox}"
                                         ToolTip="Path to cathodic CSV file (optional — leave empty for single-file mode)"/>
                                <TextBlock IsHitTestVisible="False"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"
                                           Foreground="Gray"
                                           FontStyle="Italic"
                                           Text="Leave empty to use single-file mode">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=CathodicCsvPath}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <Button x:Name="BrowseXmlOutputFolderButton"
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    Width="220"
                                    Margin="0,4,0,4"
                                    Style="{StaticResource BrowseButton}"
                                    Content="Browse Output Folder"
                                    Click="BrowseXmlOutputFolderButton_Click"/>
                            <TextBox x:Name="XmlOutputFolder"
                                     Grid.Row="3"
                                     Grid.Column="2"
                                     Margin="0,4,0,4"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="Folder where the XML file will be saved"/>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Margin="0,4,0,4"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Text="Output filename:"/>
                            <TextBox x:Name="XmlOutputFilename"
                                     Grid.Row="4"
                                     Grid.Column="2"
                                     Margin="0,4,0,4"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="Suggested XML output filename (auto-populated, editable)"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Metadata">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Institute"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"
                                       VerticalAlignment="Top"
                                       Margin="0,8,8,0"/>
                            <WrapPanel Grid.Row="0" Grid.Column="1">
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="Name" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaInstituteName" Width="120" Text="NRL" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="City" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaCity" Width="100" Text="Washington" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="State" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaState" Width="40" Text="DC" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="Country" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaCountry" Width="60" Text="USA" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                            </WrapPanel>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Material"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"
                                       VerticalAlignment="Top"
                                       Margin="0,8,8,0"/>
                            <WrapPanel Grid.Row="1" Grid.Column="1">
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="UNS Code" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaUNSCode" Width="80" Text="K31820" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="Common Name" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaCommonName" Width="160" Text="HY-80" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="Surface Prep" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaSurfacePrep" Width="180" Text="600 grit SiC" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="Exposed Area (m²)" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaExpArea" Width="110" Text="1.000000E-04" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                            </WrapPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Electrolyte"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"
                                       VerticalAlignment="Top"
                                       Margin="0,8,8,0"/>
                            <WrapPanel Grid.Row="2" Grid.Column="1">
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="Cl⁻ (M)" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaClConc" Width="55" Text="0.6" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="pH" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetapH" Width="40" Text="8" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="O₂ (M)" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaO2Conc" Width="70" Text="2.5E-4" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="S²⁻ (M)" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaS2Conc" Width="60" Text="0.08" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="Temp (°C)" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaTemperature" Width="50" Text="25" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="Conductivity (S/m)" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaConductivity" Width="55" Text="5" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,12,0">
                                    <TextBlock Text="Flow (m/s)" FontSize="11" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBox x:Name="MetaFlow" Width="50" Text="0" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                            </WrapPanel>
                        </Grid>
                    </GroupBox>

                    <DockPanel Margin="0,4,0,0">
                        <Button x:Name="GenerateXmlButton"
                                DockPanel.Dock="Left"
                                Width="160"
                                Height="44"
                                Margin="0,0,16,0"
                                Style="{StaticResource GenerateButton}"
                                Content="Generate XML"
                                Click="GenerateXmlButton_Click"/>
                        <TextBox x:Name="XmlStatusBox"
                                 Text="Status"
                                 IsReadOnly="True"
                                 Style="{StaticResource ReadOnlyTextBox}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Stretch"/>
                    </DockPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Analyze CYCPOL or POTENTIODYNAMIC Files">
            <Grid Margin="14,10,14,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BrowseAnodicPolarizationButton"
                            Grid.Column="0"
                            Width="260"
                            Height="32"
                            Style="{StaticResource BrowseButton}"
                            Content="1. Import anodic curve (or full curve)"
                            Click="BrowseAnodicPolarizationButton_Click"/>
                    <TextBox x:Name="AnodicPolarizationFilePath"
                             Grid.Column="2"
                             VerticalAlignment="Center"
                             Style="{StaticResource ReadOnlyTextBox}"
                             Text="No file selected"/>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BrowseCathodicPolarizationButton"
                            Grid.Column="0"
                            Width="260"
                            Height="32"
                            Style="{StaticResource BrowseButton}"
                            Content="2. Import cathodic curve (optional)"
                            Click="BrowseCathodicPolarizationButton_Click"/>
                    <TextBox x:Name="CathodicPolarizationFilePath"
                             Grid.Column="2"
                             VerticalAlignment="Center"
                             Style="{StaticResource ReadOnlyTextBox}"
                             Text="No file selected (optional)"/>
                </Grid>

                <DockPanel Grid.Row="2" Margin="0,0,0,8">
                    <TextBlock Text="Exposed area (cm²):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="PolarizationAreaText"
                             Width="80"
                             Margin="0,0,8,0"
                             Style="{StaticResource ModernTextBox}"
                             Text="0.495"/>
                    <Button x:Name="RunPolarizationAnalysisButton"
                            Width="220"
                            Height="36"
                            Style="{StaticResource PrimaryButton}"
                            Content="Run Butler-Volmer Analysis"
                            Click="RunPolarizationAnalysisButton_Click"/>
                </DockPanel>

                <TextBox x:Name="PolarizationAnalysisStatusBox"
                         Grid.Row="3"
                         Margin="0,0,0,8"
                         Style="{StaticResource ReadOnlyTextBox}"
                         Text="Status"/>

                <Grid Grid.Row="4" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <oxy:PlotView x:Name="PolarizationPlotView" Grid.Column="0" Margin="463,0,10,0" Grid.ColumnSpan="2"/>
                    <DataGrid x:Name="PolarizationResultsGrid"
                              AutoGenerateColumns="True"
                              IsReadOnly="True" Margin="0,221,0,-84" Grid.ColumnSpan="2"/>
                    <Label Content="HER" HorizontalAlignment="Left" Height="31" Margin="10,20,0,0" VerticalAlignment="Top" Width="132"/>
                    <Label Content="i0_HER" HorizontalAlignment="Left" Height="34" Margin="10,56,0,0" VerticalAlignment="Top" Width="56"/>
                    <TextBox HorizontalAlignment="Left" Height="34" Margin="84,56,0,0" TextWrapping="Wrap" Text="1.0e-14" VerticalAlignment="Top" Width="126"/>
                    <Label Content="beta_HER" HorizontalAlignment="Left" Height="34" Margin="314,56,0,0" VerticalAlignment="Top" Width="99"/>
                    <TextBox HorizontalAlignment="Left" Height="34" Margin="319,90,0,0" TextWrapping="Wrap" Text="0.95" VerticalAlignment="Top" Width="94"/>
                    <RadioButton Content="Fix" HorizontalAlignment="Left" Height="32" Margin="76,121,0,0" VerticalAlignment="Top" Width="70"/>
                </Grid>

                <TextBox x:Name="PolarizationSummaryBox"
                         Grid.Row="5"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Style="{StaticResource ReadOnlyTextBox}"
                         Text="Summary statistics will appear here." Margin="0,91,0,0" HorizontalAlignment="Right" Width="930"/>
                <Label Content="Label" HorizontalAlignment="Left" Height="3" Margin="401,91,0,0" Grid.Row="4" VerticalAlignment="Top" Width="4"/>
            </Grid>
        </TabItem>

        <TabItem Header="Analyze EIS Files">
            <Grid Margin="14,10,14,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <Button x:Name="BrowseEisFilesButton"
                            Width="220"
                            Height="32"
                            Margin="0,0,10,0"
                            Style="{StaticResource BrowseButton}"
                            Content="Browse EIS CSV(s)"
                            Click="BrowseEisFilesButton_Click"/>
                    <TextBox x:Name="EisFilesStatusText"
                             Style="{StaticResource ReadOnlyTextBox}"
                             Text="No files selected"/>
                </DockPanel>

                <DockPanel Grid.Row="1" Margin="0,0,0,8">
                    <TextBlock Text="Model:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="EisModelComboBox" Width="260" Margin="0,0,10,0">
                        <ComboBoxItem Content="randles_cpe_w" IsSelected="True"/>
                        <ComboBoxItem Content="randles_rc"/>
                        <ComboBoxItem Content="coating_two_time_constants"/>
                    </ComboBox>
                    <Button x:Name="RunEisAnalysisButton"
                            Width="180"
                            Height="36"
                            Style="{StaticResource PrimaryButton}"
                            Content="Run EIS Fit"
                            Click="RunEisAnalysisButton_Click"/>
                </DockPanel>

                <TextBox x:Name="EisAnalysisStatusBox"
                         Grid.Row="2"
                         Margin="0,0,0,8"
                         Style="{StaticResource ReadOnlyTextBox}"
                         Text="Status"/>

                <Grid Grid.Row="3" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <oxy:PlotView x:Name="EisNyquistPlotView" Grid.Column="0" Margin="0,0,8,0"/>
                    <oxy:PlotView x:Name="EisBodePlotView" Grid.Column="1"/>
                </Grid>

                <DataGrid x:Name="EisResultsGrid"
                          Grid.Row="4"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"/>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
